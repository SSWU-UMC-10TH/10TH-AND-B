<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:padding="16dp">

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="오늘 하루는 어땠나요?"
        android:textColor="#333333"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginTop="30dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tv_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="감정우표를 선택해주세요"
        android:textColor="#666666"
        android:textSize="14sp"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/tv_title"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageView
        android:id="@+id/ic_happy"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_marginTop="25dp"
        android:src="@drawable/ic_happy"
        app:layout_constraintTop_toBottomOf="@id/tv_subtitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />
    <TextView
        android:id="@+id/tv_happy"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="더없이 행복한 하루였어요"
        android:textSize="11sp"
        app:layout_constraintTop_toBottomOf="@id/ic_happy"
        app:layout_constraintStart_toStartOf="@id/ic_happy"
        app:layout_constraintEnd_toEndOf="@id/ic_happy" />

    <ImageView
        android:id="@+id/ic_excited"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_marginTop="25dp"
        android:src="@drawable/ic_excited"
        app:layout_constraintTop_toBottomOf="@id/tv_happy"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />
    <TextView
        android:id="@+id/tv_excited"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="들뜨고 흥분돼요"
        android:textSize="11sp"
        app:layout_constraintTop_toBottomOf="@id/ic_excited"
        app:layout_constraintStart_toStartOf="@id/ic_excited"
        app:layout_constraintEnd_toEndOf="@id/ic_excited" />

    <ImageView
        android:id="@+id/ic_soso"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_marginTop="25dp"
        android:src="@drawable/ic_soso"
        app:layout_constraintTop_toBottomOf="@id/tv_excited"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />
    <TextView
        android:id="@+id/tv_soso"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="평범한 하루였어요"
        android:textSize="11sp"
        app:layout_constraintTop_toBottomOf="@id/ic_soso"
        app:layout_constraintStart_toStartOf="@id/ic_soso"
        app:layout_constraintEnd_toEndOf="@id/ic_soso" />

    <ImageView
        android:id="@+id/ic_anxious"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_marginTop="25dp"
        android:src="@drawable/ic_anxious"
        app:layout_constraintTop_toBottomOf="@id/tv_soso"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />
    <TextView
        android:id="@+id/tv_anxious"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="생각이 많아지고 불안해요"
        android:textSize="11sp"
        app:layout_constraintTop_toBottomOf="@id/ic_anxious"
        app:layout_constraintStart_toStartOf="@id/ic_anxious"
        app:layout_constraintEnd_toEndOf="@id/ic_anxious" />

    <ImageView
        android:id="@+id/ic_angry"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_marginTop="25dp"
        android:src="@drawable/ic_angry"
        app:layout_constraintTop_toBottomOf="@id/tv_anxious"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />
    <TextView
        android:id="@+id/tv_angry"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="부글부글 화가 나요"
        android:textSize="11sp"
        app:layout_constraintTop_toBottomOf="@id/ic_angry"
        app:layout_constraintStart_toStartOf="@id/ic_angry"
        app:layout_constraintEnd_toEndOf="@id/ic_angry" />

</androidx.constraintlayout.widget.ConstraintLayout>


