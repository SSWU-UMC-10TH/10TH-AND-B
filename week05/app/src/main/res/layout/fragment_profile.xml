<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="50dp">

        <!-- 1. 프로필 이미지 및 닉네임 영역 -->
        <ImageView
            android:id="@+id/profile_image_iv"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_marginTop="40dp"
            android:background="@drawable/bg_circle_profile"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/profile_nickname_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="닉네임"
            android:textColor="@color/black"
            android:textSize="22sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/profile_image_iv" />

        <TextView
            android:id="@+id/profile_edit_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:paddingHorizontal="40dp"
            android:paddingVertical="10dp"
            android:text="프로필 수정"
            android:textColor="@color/black"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@drawable/bg_rounded_button"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/profile_nickname_tv" />

        <!-- 2. 중앙 4개 메뉴 (주문, 패스, 이벤트, 설정) -->
        <LinearLayout
            android:id="@+id/profile_menu_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:orientation="horizontal"
            android:weightSum="4"
            app:layout_constraintTop_toBottomOf="@id/profile_edit_btn">

            <!-- 주문 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_launcher_foreground"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="주문" android:textSize="12sp" android:layout_marginTop="8dp"/>
            </LinearLayout>

            <View android:layout_width="1dp" android:layout_height="match_parent" android:layout_marginVertical="5dp" android:background="#E0E0E0"/>

            <!-- 패스 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_launcher_foreground"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="패스" android:textSize="12sp" android:layout_marginTop="8dp"/>
            </LinearLayout>

            <View android:layout_width="1dp" android:layout_height="match_parent" android:layout_marginVertical="5dp" android:background="#E0E0E0"/>

            <!-- 이벤트 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_launcher_foreground"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="이벤트" android:textSize="12sp" android:layout_marginTop="8dp"/>
            </LinearLayout>

            <View android:layout_width="1dp" android:layout_height="match_parent" android:layout_marginVertical="5dp" android:background="#E0E0E0"/>

            <!-- 설정 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_launcher_foreground"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="설정" android:textSize="12sp" android:layout_marginTop="8dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- 굵은 회색 구분선 -->
        <View
            android:id="@+id/divider1"
            android:layout_width="match_parent"
            android:layout_height="10dp"
            android:layout_marginTop="20dp"
            android:background="#F5F5F5"
            app:layout_constraintTop_toBottomOf="@id/profile_menu_layout" />

        <!-- 3. 멤버 혜택 배너 -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/benefit_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp"
            app:layout_constraintTop_toBottomOf="@id/divider1">

            <TextView
                android:id="@+id/benefit_title_tv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="나이키 멤버 혜택"
                android:textColor="@color/black"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0개 사용 가능"
                android:textColor="#888888"
                android:textSize="12sp"
                android:layout_marginTop="4dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/benefit_title_tv" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_launcher_foreground"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- 굵은 회색 구분선 -->
        <View
            android:id="@+id/divider2"
            android:layout_width="match_parent"
            android:layout_height="10dp"
            android:background="#F5F5F5"
            app:layout_constraintTop_toBottomOf="@id/benefit_layout" />

        <!-- 4. 팔로잉 섹션 (가로 스크롤) -->
        <TextView
            android:id="@+id/following_title_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="20dp"
            android:text="팔로잉 (3)"
            android:textColor="@color/black"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/divider2" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="20dp"
            android:text="편집"
            android:textColor="#888888"
            android:textSize="14sp"
            app:layout_constraintBottom_toBottomOf="@id/following_title_tv"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/following_title_tv" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/following_rv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:clipToPadding="false"
            android:paddingHorizontal="20dp"
            app:layout_constraintTop_toBottomOf="@id/following_title_tv" />

        <!-- 5. 하단 가입일 정보 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:background="#F5F5F5"
            android:gravity="center"
            android:paddingVertical="20dp"
            android:text="회원 가입일: 2025년 9월"
            android:textColor="#888888"
            android:textSize="12sp"
            app:layout_constraintTop_toBottomOf="@id/following_rv" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>